generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  client
  super_admin
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
}

enum CallStatus {
  pending
  in_progress
  completed
  failed
  no_answer
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      UserRole @default(client)
  approved  Boolean  @default(false)
  company   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents    Agent[]
  campaigns Campaign[]
  integrations Integration[]

  @@map("users")
}

model Agent {
  id               String   @id @default(cuid())
  name             String
  description      String?
  systemPrompt     String
  firstMessage     String?
  firstMessageMode String   @default("dynamic")
  llmModel         String   @default("gpt-4.1")
  voiceId          String   @default("minimax-Camille")
  voiceSpeed       Float    @default(1.0)
  voiceTemperature Float    @default(1.0)
  language         String   @default("fr-FR")
  maxCallDuration  Int      @default(300)
  silenceTimeout   Int      @default(10)
  endCallOnSilence Boolean  @default(true)
  enableRecording  Boolean  @default(true)
  postCallAnalysis Boolean  @default(false)
  postCallPrompt   String?
  postCallWebhook  String?
  safetyMessage    String?
  maxSafetyRetries Int      @default(3)
  functions        Json     @default("[]")
  mcpConfig        Json     @default("[]")
  config           Json     @default("{}")
  notificationEmail    String?
  notificationPhone    String?
  notificationChannels Json     @default("[]")
  retellAgentId    String?  @unique
  retellLlmId      String?  @unique
  published        Boolean  @default(false)
  archived         Boolean  @default(false)
  userId           String
  orgId            String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaigns Campaign[]

  @@map("agents")
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  description     String?
  status          CampaignStatus @default(draft)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // Scheduling
  callDays        Json           @default("[1,2,3,4,5]") // array of day numbers (0=Sunday..6=Saturday)
  callStartTime   String         @default("09:00")
  callEndTime     String         @default("17:00")
  timezoneMode    String         @default("fixed") // "auto" or "fixed"
  timezone        String         @default("Europe/Paris")
  // Retry
  maxRetries      Int            @default(1)
  retryIntervalH  Int            @default(1)
  // Call rate
  callRateCount   Int            @default(20)
  callRateMinutes Int            @default(1)
  // Phone numbers
  phoneNumberIds  Json           @default("[]") // array of phone number IDs
  // Post-call workflows
  workflows       Json           @default("[]") // Array of workflow rules
  userId          String
  orgId           String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent          @relation(fields: [agentId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contacts Contact[]
  calls    Call[]

  @@map("campaigns")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  company     String?
  notes       String?
  tags        String[] @default([])
  metadata    Json     @default("{}")
  score       Int?
  scoreLabel  String?
  scoreReason String?
  nextAction  String?
  // Contacts can belong to a campaign (legacy) or be standalone CRM contacts
  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  // CRM ownership
  userId      String?
  orgId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  calls Call[]

  @@map("contacts")
}

model Call {
  id            String     @id @default(cuid())
  status        CallStatus @default(pending)
  retellCallId  String?    @unique
  duration      Int?
  startedAt     DateTime?
  endedAt       DateTime?
  transcript    String?
  summary       String?
  sentiment     String?
  outcome       String?
  recordingUrl  String?
  metadata      Json       @default("{}")
  campaignId    String?
  campaign      Campaign?  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId     String?
  contact       Contact?   @relation(fields: [contactId], references: [id])
  // For standalone calls (not campaign-related)
  userId        String?
  orgId         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  demands   CallDemand[]

  @@map("calls")
}

model CallDemand {
  id        String   @id @default(cuid())
  callId    String
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  category  String   // slug: "fiche_de_paie", "rendez_vous_dermato"
  label     String   // human-readable: "Demande de fiche de paie"
  details   String?  // context from transcript
  urgency   String   @default("medium") // "low" | "medium" | "high"
  orgId     String
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([callId])
  @@map("call_demands")
}

model WeeklyReport {
  id              String    @id @default(cuid())
  orgId           String
  periodStart     DateTime
  periodEnd       DateTime
  totalCalls      Int
  totalDemands    Int
  topCategories   Json      @default("[]")
  kpis            Json      @default("{}")
  recommendations Json      @default("[]")
  profession      String?
  rawAnalysis     Json?
  emailSentAt     DateTime?
  createdAt       DateTime  @default(now())

  @@unique([orgId, periodStart])
  @@index([orgId, createdAt])
  @@map("weekly_reports")
}

model CompanyProfile {
  id          String   @id @default(cuid())
  name        String
  activity    String   // ex: "Agence immobiliere", "Cabinet dentaire"
  description String?  // description libre de l'activite
  address     String?
  city        String?
  zipCode     String?
  country     String   @default("France")
  phone       String?
  email       String?
  website     String?
  openingHours String? // ex: "Lundi-Vendredi 9h-18h"
  tone        String   @default("professionnel") // professionnel, amical, formel
  targetAudience String? // ex: "Particuliers et PME"
  uniqueValue String?  // proposition de valeur unique
  orgId       String   @unique
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_profiles")
}

model WebhookConfig {
  id        String   @id @default(cuid())
  name      String
  url       String
  secret    String?
  events    String[] @default([]) // call_ended, call_analyzed, lead_hot, lead_warm, campaign_completed
  enabled   Boolean  @default(true)
  userId    String
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("webhook_configs")
}

model WebhookLog {
  id            String   @id @default(cuid())
  webhookId     String
  event         String
  payload       Json     @default("{}")
  statusCode    Int?
  response      String?
  success       Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("webhook_logs")
}

model PhoneNumber {
  id            String   @id @default(cuid())
  phoneNumber   String   @unique // E.164 format: +33612345678
  nickname      String?
  provider      String   @default("twilio") // twilio, sip
  orgId         String
  userId        String   // who imported it
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@map("phone_numbers")
}

model Integration {
  id        String   @id @default(cuid())
  type      String
  name      String
  config    Json     @default("{}")
  enabled   Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

model Appointment {
  id            String   @id @default(cuid())
  patientName   String
  patientPhone  String
  patientEmail  String?
  practitioner  String   // nom du praticien
  motif         String   // motif de consultation
  date          DateTime
  duration      Int      @default(30) // minutes
  status        String   @default("confirmed") // confirmed, cancelled, completed, no_show
  source        String   @default("agent_ia") // agent_ia, manual, doctolib_sync
  notes         String?
  externalId    String?  // ID Doctolib ou autre systeme
  callId        String?  // lien vers l'appel qui a genere le RDV
  userId        String
  orgId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("appointments")
}

enum SubscriptionStatus {
  active
  paused
  cancelled
}

enum FreeTrialType {
  none
  subscription_only
  minutes_only
  both
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
}

model Subscription {
  id              String             @id @default(cuid())
  orgId           String             @unique
  monthlyPrice    Int                // centimes (ex: 29900 = 299€)
  pricePerMinute  Int                // centimes (ex: 15 = 0.15€)
  freeTrialType   FreeTrialType      @default(none)
  freeTrialMonths Int                @default(1)
  startDate       DateTime           @default(now())
  status          SubscriptionStatus @default(active)
  companyName     String
  companyAddress  String?
  companySiret    String?
  companyVat      String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  invoices Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique // INV-2026-0001
  orgId              String
  subscriptionId     String
  subscription       Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  periodMonth        Int           // 1-12
  periodYear         Int
  subscriptionAmount Int           // centimes
  minutesUsed        Int           // secondes totales
  minutesAmount      Int           // centimes
  totalHT            Int           // centimes
  tvaRate            Int           @default(2000) // 2000 = 20.00%
  tvaAmount          Int           // centimes
  totalTTC           Int           // centimes
  status             InvoiceStatus @default(draft)
  paidAt             DateTime?
  createdAt          DateTime      @default(now())

  @@unique([orgId, periodMonth, periodYear])
  @@map("invoices")
}

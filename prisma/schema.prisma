generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  client
  super_admin
}

enum CampaignStatus {
  draft
  scheduled
  running
  paused
  completed
}

enum CallStatus {
  pending
  in_progress
  completed
  failed
  no_answer
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  role      UserRole @default(client)
  company   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agents    Agent[]
  campaigns Campaign[]
  integrations Integration[]

  @@map("users")
}

model Agent {
  id               String   @id @default(cuid())
  name             String
  description      String?
  systemPrompt     String
  firstMessage     String?
  firstMessageMode String   @default("dynamic")
  llmModel         String   @default("gpt-4.1")
  voiceId          String   @default("minimax-Camille")
  voiceSpeed       Float    @default(1.0)
  voiceTemperature Float    @default(1.0)
  language         String   @default("fr-FR")
  maxCallDuration  Int      @default(300)
  silenceTimeout   Int      @default(10)
  endCallOnSilence Boolean  @default(true)
  enableRecording  Boolean  @default(true)
  postCallAnalysis Boolean  @default(false)
  postCallPrompt   String?
  postCallWebhook  String?
  safetyMessage    String?
  maxSafetyRetries Int      @default(3)
  functions        Json     @default("[]")
  mcpConfig        Json     @default("[]")
  config           Json     @default("{}")
  retellAgentId    String?  @unique
  retellLlmId      String?  @unique
  published        Boolean  @default(false)
  userId           String
  orgId            String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaigns Campaign[]

  @@map("agents")
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  description     String?
  status          CampaignStatus @default(draft)
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  // Scheduling
  callDays        Json           @default("[1,2,3,4,5]") // array of day numbers (0=Sunday..6=Saturday)
  callStartTime   String         @default("09:00")
  callEndTime     String         @default("17:00")
  timezoneMode    String         @default("fixed") // "auto" or "fixed"
  timezone        String         @default("Europe/Paris")
  // Retry
  maxRetries      Int            @default(1)
  retryIntervalH  Int            @default(1)
  // Call rate
  callRateCount   Int            @default(20)
  callRateMinutes Int            @default(1)
  // Phone numbers
  phoneNumberIds  Json           @default("[]") // array of phone number IDs
  // Post-call workflows
  workflows       Json           @default("[]") // Array of workflow rules
  userId          String
  orgId           String?
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent          @relation(fields: [agentId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  contacts Contact[]
  calls    Call[]

  @@map("campaigns")
}

model Contact {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  metadata    Json     @default("{}")
  score       Int?
  scoreLabel  String?
  scoreReason String?
  nextAction  String?
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  calls Call[]

  @@map("contacts")
}

model Call {
  id            String     @id @default(cuid())
  status        CallStatus @default(pending)
  retellCallId  String?    @unique
  duration      Int?
  startedAt     DateTime?
  endedAt       DateTime?
  transcript    String?
  summary       String?
  sentiment     String?
  outcome       String?
  recordingUrl  String?
  metadata      Json       @default("{}")
  campaignId    String
  campaign      Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact    @relation(fields: [contactId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("calls")
}

model Integration {
  id        String   @id @default(cuid())
  type      String
  name      String
  config    Json     @default("{}")
  enabled   Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}
